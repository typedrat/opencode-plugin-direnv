{
  "name": "opencode-plugin-direnv",
  "version": "0.1.0",
  "description": "OpenCode plugin that injects direnv-managed environment into agent and user shell sessions.",
  "keywords": ["opencode", "opencode-plugin", "direnv"],
  "license": "MIT",
  "author": "typedrat",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "bun build ./src/index.ts --target=bun --outdir=dist --external @opencode-ai/plugin && tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "*",
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
